# Coverage artifacts — all transient, regenerate via pytest
.coverage
.coverage.*
coverage.xml
htmlcov/
coverage.json
coverage_project.json
!cogant/coverage.json

# pytest / hypothesis
.pytest_cache/
.hypothesis/

# Python build / runtime caches
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.ruff_cache/
.mypy_cache/
uv.lock

# Output artifacts
output/
cogant/_rnd/
cogant/out/

# Parent project ignore rules hide untracked files inside nested cogant/ dirs.
# Keep this intentionally added MkDocs page visible without surfacing generated
# package outputs or unrelated sidecar notes.
!cogant/
cogant/*
!cogant/docs/
cogant/docs/*
!cogant/docs/evaluation/
cogant/docs/evaluation/*
!cogant/docs/evaluation/GNN_V2_AUDIT_SURFACE.md
!cogant/docs/rnd/
cogant/docs/rnd/*
!cogant/docs/rnd/organization_state_spaces.md

# OS / editor cruft
.DS_Store
**/.DS_Store

# Cursor / IDE state (shell hook artifacts, project metadata)
.cursor/

# Accidental literal-tilde directory created by misquoted shell expansions
/~/
