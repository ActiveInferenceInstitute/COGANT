# Coverage artifacts — all transient, regenerate via pytest
.coverage
.coverage.*
coverage.xml
htmlcov/
coverage.json
!cogant/coverage.json

# pytest / hypothesis
.pytest_cache/
.hypothesis/

# Python build / runtime caches
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.ruff_cache/
.mypy_cache/
uv.lock

# Output artifacts
output/
cogant/_rnd/
cogant/out/

# OS / editor cruft
.DS_Store
**/.DS_Store

# Cursor / IDE state (shell hook artifacts, project metadata)
.cursor/

# Accidental literal-tilde directory created by misquoted shell expansions
/~/
