# COGANT manuscript configuration template
# Copy to config.yaml and customize. Read by `infrastructure/core/config_loader.py` when rendered via the template pipeline.

paper:
  title: "COGANT: Codebase-to-GNN Translation"
  subtitle: "Program Graphs, Intermediate Representations, and Practice of the Python Pipeline"
  version: "0.5.0"
  date: "2026-04-15"

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"
    email: "your.email@institution.edu"
    affiliation: "Your Affiliation"
    corresponding: true

publication:
  doi: ""
  journal: ""
  volume: ""
  pages: ""
  year: "2026"

keywords:
  - "program analysis"
  - "Generalized Notation Notation (GNN)"
